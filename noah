<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Online Store</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f5f5f5;
    }

    header {
      background: #111;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .container {
      max-width: 1000px;
      margin: auto;
      padding: 20px;
    }

    .intro {
      text-align: center;
      margin-bottom: 30px;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      text-align: center;
    }

    .card img {
      width: 100%;
      border-radius: 10px;
      height: 180px;
      object-fit: cover;
    }

    .price {
      font-weight: bold;
      margin: 10px 0;
    }

    .btn {
      display: inline-block;
      padding: 10px 15px;
      background: black;
      color: white;
      text-decoration: none;
      border-radius: 5px;
    }

    .btn:hover {
      background: #333;
    }

    footer {
      text-align: center;
      padding: 20px;
      margin-top: 40px;
      background: #111;
      color: white;
    }
  </style>
</head>

<body>

<header>
  <h1>My Online Store</h1>
  <p>Simple products, great prices</p>
</header>

<div class="container">

  <div class="intro">
    <h2>Welcome 👋</h2>
    <p>Browse my products below. Click buy to order via email or payment link.</p>
  </div>

  <div class="products">

    <!-- PRODUCT 1 -->
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Product 1">
      <h3>Product One</h3>
      <p>High quality item description goes here.</p>
      <div class="price">$19.99</div>
      <a class="btn" href="mailto:your@email.com?subject=Order Product One">Buy Now</a>
    </div>

    <!-- PRODUCT 2 -->
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Product 2">
      <h3>Product Two</h3>
      <p>Another awesome product description.</p>
      <div class="price">$29.99</div>
      <a class="btn" href="mailto:your@email.com?subject=Order Product Two">Buy Now</a>
    </div>

    <!-- PRODUCT 3 -->
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Product 3">
      <h3>Product Three</h3>
      <p>Best seller item description here.</p>
      <div class="price">$39.99</div>
      <a class="btn" href="mailto:your@email.com?subject=Order Product Three">Buy Now</a>
    </div>

  </div>
</div>

<footer>
  <p>© 2026 My Online Store | All rights reserved</p>
</footer>

</body>
</html>
